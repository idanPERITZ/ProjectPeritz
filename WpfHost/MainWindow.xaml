<Window x:Class="WpfHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Height="500"
        Width="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border CornerRadius="16"
            Background="#121212"
            BorderBrush="#2A2A2A"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" 
                              Direction="270" 
                              ShadowDepth="15" 
                              BlurRadius="30"
                              Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- תמונה בצד ימין -->
            <Border Grid.Column="1" IsHitTestVisible="False" Margin="0,40,0,40">
                <Border.OpacityMask>
                    <LinearGradientBrush StartPoint="1,0.5" EndPoint="0,0.5">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="Black" Offset="0.15"/>
                        <GradientStop Color="Black" Offset="1"/>
                    </LinearGradientBrush>
                </Border.OpacityMask>

            </Border>

            <Grid Grid.ColumnSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Height="50" LastChildFill="False" MouseDown="TopBar_MouseDown">
                    <TextBlock Text="Chess Service"
                               Foreground="#666666"
                               FontSize="11"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="25,0"/>

                    <Button DockPanel.Dock="Right"
                            Width="32" Height="32"
                            Margin="15"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#555"
                            Content="✕"
                            FontSize="14"
                            Click="CloseService_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="#E81123"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DockPanel>

                <StackPanel Grid.Row="1" 
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Left" 
                            Margin="50,0,0,20">

                    <Border Background="#1A331A"
                            BorderBrush="#2D5A2D"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,3"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#4CAF50" Margin="0,0,6,0"/>
                            <TextBlock Text="Service Online" Foreground="#8BC34A" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Chess Service &#x0a;Running" 
                               FontSize="48" 
                               FontWeight="ExtraBold" 
                               Foreground="White" 
                               Margin="0,0,0,10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
                                <Setter Property="LineHeight" Value="48"/>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Text="The service is active." 
                               Foreground="#888" 
                               FontSize="14" 
                               Margin="0,0,0,30">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
                                <Setter Property="LineHeight" Value="20"/>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Button Content="Stop Service"
                            Width="180"
                            Height="45"
                            FontSize="12"
                            FontWeight="Bold"
                            Foreground="White"
                            HorizontalAlignment="Left"
                            Click="CloseService_Click"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btn" Background="#222" CornerRadius="4" BorderBrush="#333" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btn" Property="Background" Value="#CC2B2B"/>
                                        <Setter TargetName="btn" Property="BorderBrush" Value="#FF4444"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>